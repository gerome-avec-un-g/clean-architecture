{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "periods/tax-period.json",
  "title": "TaxPeriod",
  "schemaVersion": "1.0.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "taxYear",
    "from",
    "to"
  ],
  "properties": {
    "taxYear": {
      "type": "integer",
      "minimum": 1900
    },
    "from": {
      "type": "string",
      "format": "date"
    },
    "to": {
      "type": "string",
      "format": "date"
    }
  }
}