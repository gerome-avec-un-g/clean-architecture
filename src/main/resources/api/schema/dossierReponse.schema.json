{
  "$comment": "Schéma JSON décrivant la réponse à une création/modification de 'dossier' pour l'API (version v1.0.0).",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dossier-reponse.json",
  "title": "Réponse à une demande de garantie Crédit Logement",
  "schemaVersion": "1.00.00-SNAPSHOT",
  "description": "Réponse contenant les erreurs rencontrées OU l'état des prêts pour lesquels une demande de garantie a été faite",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "erreurs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["norme", "liste"],
      "properties": {
        "norme": {
          "$ref": "normes.schema.json#/$defs/normesCodeErreurs"
        },
        "liste": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/erreur"
          }
        }
      }
    },
    "reponseDossier": {
      "$ref": "#/$defs/reponseDossier"
    }
  },
  "oneOf": [
    {
      "required": [
        "erreurs"
      ]
    },
    {
      "required": [
        "reponseDossier"
      ]
    }
  ],
  "$defs": {
 "erreur": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "libelle"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1,
          "maxLength": 30
        },
        "libelle": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        }
      }
    },

    "reponseDossier": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "referenceDossierPartenaire",
        "referenceDossierCreditLogement",
        "baremeTarification",
        "pret"
      ],
      "properties": {
        "referenceDossierPartenaire": {
          "type": "string",
          "minLength": 1,
          "maxLength": 32
        },
        "referenceDossierCreditLogement": {
          "type": "string",
          "minLength": 10,
          "maxLength": 10
        },
        "baremeTarification": {
          "type": "object",
          "required": ["code", "norme"],
          "properties": {
            "code": {
              "type": "string",
              "minLength": 1,
              "maxLength": 1
            },
            "norme": {
              "$ref": "normes.schema.json#/$defs/normesCodeBaremeTarification"
            }
          },
          "additionalProperties": false
        },
        "pret": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/pret"
          }
        }
      }
    },
    "pret": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "referencePretPartenaire",
        "referencePretCreditLogement",
        "etatPret"
      ],
      "properties": {
        "referencePretCreditLogement": {
          "type": "string",
          "minLength": 12,
          "maxLength": 12
        },
        "referencePretPartenaire": {
          "type": "string",
          "minLength": 1,
          "maxLength": 32
        },
        "referencePretUnique": {
          "type": "string",
          "minLength": 1,
          "maxLength": 32
        },
        "etatPret": {
          "type": "object",
          "required": ["code", "norme"],
          "properties": {
            "code": {
            "type": "string",
            "minLength": 1,
            "maxLength":2
            },
            "norme": {
              "$ref": "normes.schema.json#/$defs/normesCodeEtat"
            }
          },
          "additionalProperties": false
        },
        "montantCommissionCaution": {
          "description": "Montant de la commission de caution (En cas d'accord)",
          "anyOf": [
            {
              "type": "number",
              "minimum": 0,
              "maximum": 100000000,
              "multipleOf": 0.01
            },
            {
              "type": "null"
            }
          ]
        },
        "montantFondMutuelGarantie": {
          "description": "Montant du fonds mutuel de garantie (En cas d'accord)",
          "anyOf": [
            {
              "type": "number",
              "minimum": 0,
              "maximum": 100000000,
              "multipleOf": 0.01
            },
            {
              "type": "null"
            }
          ]
        },
        "reserves": {
          "$ref": "#/$defs/reserves"
        },
        "garantiesComplementaires": {
          "$ref": "#/$defs/garantiesComplementaires"
        },
        "libelleRefus": {
          "description": "Libellé du refus (En cas de refus)",
          "anyOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 40
            },
            {
              "type": "null"
            }
          ]
        },
        "codeRefus": {
          "description": "Code du refus (En cas de refus)",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "dependentRequired": {
        "libelleRefus": [
          "codeRefus"
        ],
        "codeRefus": [
          "libelleRefus"
        ]
      }
    },
    "reserves": {
      "type": "array",
      "minItems": 0,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "libelleReserve": {
            "type": "string",
            "minLength": 1,
            "maxLength": 75
          }
        },
        "required": [
          "libelleReserve"
        ]
      }
    },
    "garantiesComplementaires": {
      "type": "array",
      "minItems": 0,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "libelleGarantieCompl": {
            "type": "string",
            "minLength": 1,
            "maxLength": 75
          }
        },
        "required": [
          "libelleGarantieCompl"
        ]
      }
    }
  }
}