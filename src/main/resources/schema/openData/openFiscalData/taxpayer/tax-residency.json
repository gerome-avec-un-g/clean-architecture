{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taxpayer/tax-residency.json",
  "title": "TaxResidency",
  "schemaVersion": "1.0.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "country",
    "from"
  ],
  "properties": {
    "country": {
      "type": "string",
      "pattern": "^[A-Z]{2}$"
    },
    "from": {
      "type": "string",
      "format": "date"
    },
    "to": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    }
  }
}