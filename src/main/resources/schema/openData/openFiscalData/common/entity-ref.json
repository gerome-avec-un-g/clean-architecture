{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "common/entity-ref.json",
  "title": "EntityRef",
  "schemaVersion": "1.0.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "lei": {
      "type": "string"
    },
    "siren": {
      "type": "string",
      "pattern": "^[0-9]{9}$"
    },
    "country": {
      "type": "string",
      "pattern": "^[A-Z]{2}$"
    }
  }
}