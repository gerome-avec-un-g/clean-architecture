{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "common/monetary-amount.json",
  "title": "MonetaryAmount (ISO 4217)",
  "schemaVersion": "1.0.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "amount",
    "currency"
  ],
  "properties": {
    "amount": {
      "type": "number",
      "format": "double"
    },
    "currency": {
      "type": "string",
      "pattern": "^[A-Z]{3}$"
    }
  }
}